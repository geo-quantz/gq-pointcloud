<?xml version="1.0" encoding="UTF-8"?>
<Wix xmlns="http://schemas.microsoft.com/wix/2006/wi">
    <Product Id="*" Name="PDAL Filter CLI" Language="1033" Version="0.1.0.0" Manufacturer="GeoQuantz" UpgradeCode="d1b1c2a3-e4f5-4a5b-9c6d-7e8f9a0b1c2d">
        <Package InstallerVersion="200" Compressed="yes" InstallScope="perMachine" />

        <MajorUpgrade DowngradeErrorMessage="A newer version of [ProductName] is already installed." />
        <MediaTemplate EmbedCab="yes" />

        <Feature Id="ProductFeature" Title="PDAL Filter CLI" Level="1">
            <ComponentGroupRef Id="ProductComponents" />
        </Feature>
    </Product>

    <Fragment>
        <Directory Id="TARGETDIR" Name="SourceDir">
            <Directory Id="ProgramFilesFolder">
                <Directory Id="INSTALLFOLDER" Name="PDAL Filter CLI" />
            </Directory>
        </Directory>
    </Fragment>

    <Fragment>
        <ComponentGroup Id="ProductComponents" Directory="INSTALLFOLDER">
            <Component Id="MainExecutable" Guid="a1b2c3d4-e5f6-4b5c-8d7e-9f0a1b2c3d4e">
                <File Id="PDALFilterEXE" Source="dist\pdal_filter.exe" KeyPath="yes" Checksum="yes" />
                <!-- Add to PATH -->
                <Environment Id="PATH" Name="PATH" Value="[INSTALLFOLDER]" Permanent="no" Part="last" Action="set" System="yes" />
            </Component>
        </ComponentGroup>
    </Fragment>
</Wix>
